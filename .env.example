# Database
DATABASE_URL="postgresql://user:password@localhost:5432/radar_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# FastAPI Backend
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Scheduler
PLAYWRIGHT_HEADLESS=true
SCHEDULER_TIMEZONE=UTC
# Set to true on Railway when you're ready to activate automated checks for paying users.
# Leave as false (or unset) in dev and on demo/test accounts to avoid burning API tokens.
SCHEDULER_ENABLED=false
# Comma-separated list of email addresses to exclude from automated scheduling.
# Add your own dev account and any demo accounts here.
# Example: SCHEDULER_EXCLUDED_EMAILS=demo@radar.app,you@example.com
SCHEDULER_EXCLUDED_EMAILS=adamabrahamson99@gmail.com

# Stripe Subscriptions
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_STARTER_MONTHLY_PRICE_ID="price_..."
STRIPE_STARTER_ANNUAL_PRICE_ID="price_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_UNLIMITED_MONTHLY_PRICE_ID="price_..."
STRIPE_UNLIMITED_ANNUAL_PRICE_ID="price_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Radar <notifications@your-domain.com>"

# Internal API secret — shared between Next.js and FastAPI for server-to-server calls
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="your-internal-secret-here"

# Developer accounts — comma-separated emails always treated as PRO/ACTIVE.
# These accounts see all Pro features and the manual check button, but are
# never auto-scheduled (pair with SCHEDULER_EXCLUDED_EMAILS on FastAPI).
# Example: DEV_ACCOUNT_EMAILS=you@example.com,teammate@example.com
DEV_ACCOUNT_EMAILS=

# ── Validator ──────────────────────────────────────────────────────────────────
# Global concurrent validator fetches across all domains
VALIDATOR_MAX_CONCURRENT=10
# Max concurrent fetches per individual domain (prevents hammering one site)
VALIDATOR_PER_DOMAIN_MAX=2
# Per-request timeout in seconds
VALIDATOR_TIMEOUT_SEC=8.0
# Retry attempts on transient failures (429, 5xx, timeout, connection error)
VALIDATOR_RETRY_ATTEMPTS=2
# Base backoff in seconds between retries (doubles each attempt)
VALIDATOR_RETRY_BACKOFF_SEC=1.5

# ── Domain health ──────────────────────────────────────────────────────────────
# Min failure rate in a single run to trigger domain backoff (0.0–1.0)
DOMAIN_FAILURE_THRESHOLD=0.5
# Base backoff in seconds for first failure (doubles per consecutive failure)
DOMAIN_BACKOFF_BASE_SEC=300
# Maximum backoff cap in seconds (default: 24 hours)
DOMAIN_BACKOFF_MAX_SEC=86400
# Anti-bot backoff multiplier (anti-bot backoff = base * this value)
DOMAIN_ANTIBOT_BACKOFF_MULTIPLIER=2
