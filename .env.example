# Database
DATABASE_URL="postgresql://user:password@localhost:5432/radar_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# FastAPI Backend
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Scheduler (Phase 2)
PLAYWRIGHT_HEADLESS=true
SCHEDULER_TIMEZONE=UTC

# Stripe Subscriptions
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_STARTER_MONTHLY_PRICE_ID="price_..."
STRIPE_STARTER_ANNUAL_PRICE_ID="price_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_UNLIMITED_MONTHLY_PRICE_ID="price_..."
STRIPE_UNLIMITED_ANNUAL_PRICE_ID="price_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Radar <notifications@your-domain.com>"

# Internal API secret — shared between Next.js and FastAPI for server-to-server calls
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="your-internal-secret-here"